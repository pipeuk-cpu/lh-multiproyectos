---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import BeforeAfterSlider from "../components/BeforeAfterSlider.astro";
import { waLink, SITE } from "../config/site";
import tumbagaMirador from "../assets/tumbaga/mirador.png";

const businessLines = [
  {
    title: "Condominio Tumbaga",
    tagline: "Tributo al Territorio Quimbaya",
    description: "Lotes campestres desde 1.500 m² vía Cartago–Cerritos, Mirador Río La Vieja.",
    href: "/tumbaga",
    image: tumbagaMirador,
  },
  {
    title: "La Aldea, Alcalá",
    tagline: "Tu finca entre cafetales",
    description: "Lotes para fincas campestres cerca de Filandia, en el Paisaje Cultural Cafetero.",
    href: "/la-aldea",
  },
  {
    title: "Locales Comerciales",
    tagline: "Arriendo en Cartago",
    description: "Espacios comerciales bien ubicados en el corazón de Cartago.",
    href: "/locales",
  },
];

const whyEjeCafetero = [
  { title: "Clima privilegiado", desc: "Montaña con temperatura agradable todo el año." },
  { title: "Valorización constante", desc: "Zona en crecimiento dentro del Eje Cafetero." },
  { title: "Conexión Cartago–Pereira", desc: "A minutos de las principales ciudades del Valle y Risaralda." },
  { title: "Paisaje Cultural Cafetero", desc: "Entorno declarado Patrimonio de la Humanidad por la UNESCO." },
];
---

<Layout
  title="LH Multiproyectos SAS | Lotes campestres y locales comerciales en el Eje Cafetero"
  description="Lotes campestres en Tumbaga y La Aldea, además de locales comerciales en arriendo en Cartago, Valle del Cauca."
  whatsappMessage={SITE.whatsappMessages.home}
>
  <!-- Hero -->
  <section class="relative flex min-h-[90vh] items-center justify-center overflow-hidden bg-brand-forest text-brand-cream">
    <Image
      src={tumbagaMirador}
      alt="Vista aérea del mirador Río La Vieja, Cartago"
      class="absolute inset-0 h-full w-full object-cover"
      width={1200}
      priority
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-charcoal/70 via-brand-charcoal/40 to-brand-forest/80"></div>
    <span class="absolute top-6 left-1/2 -translate-x-1/2 rounded bg-black/30 px-3 py-1 text-center font-display text-xs uppercase tracking-wide text-brand-cream/50">
      [PENDIENTE: video de dron a pantalla completa]
    </span>
    <div class="relative z-10 mx-auto max-w-3xl px-4 text-center">
      <h1 class="font-display text-4xl font-bold uppercase leading-tight tracking-wide md:text-6xl">
        Vemos lo que tu tierra puede llegar a ser.
      </h1>
      <p class="mt-5 text-lg text-brand-cream/90 md:text-xl">
        Lotes campestres, casas y locales comerciales en el corazón del Eje Cafetero.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/tumbaga"
          class="w-full rounded-full bg-brand-gold px-8 py-3 text-center font-display text-sm uppercase tracking-wide text-brand-charcoal transition-transform hover:scale-105 sm:w-auto"
        >
          Conoce Tumbaga
        </a>
        <a
          href={waLink(SITE.whatsappMessages.home)}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full rounded-full border-2 border-brand-cream px-8 py-3 text-center font-display text-sm uppercase tracking-wide text-brand-cream transition-transform hover:scale-105 sm:w-auto"
        >
          Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- El concepto -->
  <section class="bg-brand-cream px-4 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-display text-3xl font-bold uppercase tracking-wide text-brand-forest md:text-4xl">
        De lo que es → a lo que puede ser
      </h2>
      <p class="mt-4 text-brand-charcoal/80">
        Vendemos la transformación, no el potrero. Arrastra para comparar el terreno real con la propiedad posible.
      </p>
    </div>
    <div class="mt-10">
      <BeforeAfterSlider beforeImage={tumbagaMirador} beforeAlt="Vista aérea real del mirador en Tumbaga" />
    </div>
  </section>

  <!-- Líneas de negocio -->
  <section class="bg-brand-forest px-4 py-16 text-brand-cream md:px-8 md:py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-3xl font-bold uppercase tracking-wide md:text-4xl">
        Nuestras líneas de negocio
      </h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {businessLines.map((line) => (
          <a
            href={line.href}
            class="group flex flex-col overflow-hidden rounded-xl border border-brand-gold/30 bg-brand-charcoal/40 transition-colors hover:border-brand-gold"
          >
            <div class="relative flex h-48 items-center justify-center overflow-hidden bg-gradient-to-br from-brand-charcoal to-brand-forest">
              {line.image ? (
                <Image
                  src={line.image}
                  alt={line.title}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  width={500}
                />
              ) : (
                <span class="px-4 text-center font-display text-xs uppercase tracking-wide text-brand-cream/40">
                  [PENDIENTE: imagen — {line.title}]
                </span>
              )}
            </div>
            <div class="flex flex-1 flex-col gap-2 p-6">
              <h3 class="font-display text-xl font-bold uppercase tracking-wide">{line.title}</h3>
              <p class="font-display text-sm uppercase tracking-wide text-brand-gold-light">{line.tagline}</p>
              <p class="mt-1 text-sm text-brand-cream/80">{line.description}</p>
              <span class="mt-3 font-display text-xs uppercase tracking-wide text-brand-gold-light group-hover:underline">
                Ver más →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué el Eje Cafetero -->
  <section class="bg-brand-cream px-4 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-3xl font-bold uppercase tracking-wide text-brand-forest md:text-4xl">
        Por qué el Eje Cafetero
      </h2>
      <div class="mt-10 grid gap-8 sm:grid-cols-2 md:grid-cols-4">
        {whyEjeCafetero.map((item) => (
          <div class="text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-gold/15 text-brand-gold">
              <svg viewBox="0 0 24 24" class="h-7 w-7 fill-current"><circle cx="12" cy="12" r="9"/></svg>
            </div>
            <h3 class="mt-4 font-display text-base font-bold uppercase tracking-wide text-brand-forest">
              {item.title}
            </h3>
            <p class="mt-2 text-sm text-brand-charcoal/70">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-brand-charcoal px-4 py-20 text-center text-brand-cream md:px-8">
    <h2 class="font-display text-3xl font-bold uppercase tracking-wide md:text-4xl">
      Te mereces todo con tu familia.
    </h2>
    <p class="mt-4 text-brand-cream/80">Empieza hoy el camino hacia tu finca o casa campestre.</p>
    <a
      href={waLink(SITE.whatsappMessages.home)}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-block rounded-full bg-brand-gold px-10 py-3 font-display text-sm uppercase tracking-wide text-brand-charcoal transition-transform hover:scale-105"
    >
      Escríbenos por WhatsApp
    </a>
  </section>
</Layout>
