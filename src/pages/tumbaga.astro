---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import BeforeAfterSlider from "../components/BeforeAfterSlider.astro";
import TumbagaLotMap from "../components/TumbagaLotMap.astro";
import { waLink, SITE } from "../config/site";
import { tumbagaLots, lotWhatsappMessage } from "../data/tumbaga-lots";
import tumbagaMirador from "../assets/tumbaga/mirador.png";
import antesRender from "../assets/tumbaga/antes-render.jpg";
import despuesRender from "../assets/tumbaga/despues-render.png";
import galeria1 from "../assets/tumbaga/lote-5.jpg";
import galeria2 from "../assets/tumbaga/lote-8.jpg";
import galeria3 from "../assets/tumbaga/lote-11.jpg";
import galeria4 from "../assets/tumbaga/lote-12.jpg";
import galeria5 from "../assets/tumbaga/lote-14.jpg";
import galeria6 from "../assets/tumbaga/lote-15.jpg";

const galeria = [galeria1, galeria2, galeria3, galeria4, galeria5, galeria6];

const datosClave = [
  "Desde 1.500 m²",
  "Vía Cartago–Cerritos",
  "Mirador Río La Vieja",
  "Tributo al Territorio Quimbaya",
];

const distancias = [
  { lugar: "Cartago", tiempo: "3 min" },
  { lugar: "Pereira", tiempo: "~25 min" },
  { lugar: "Aeropuerto Santa Ana", tiempo: "[PENDIENTE: tiempo]" },
];

const mapsSrc =
  "https://www.google.com/maps?q=Via+Cartago-Cerritos,Cartago,Valle+del+Cauca,Colombia&output=embed";
---

<Layout
  title="Condominio Tumbaga | Lotes campestres vía Cartago–Cerritos"
  description="Lotes campestres desde 1.500 m² con y sin casa construida, vía Cartago–Cerritos, Mirador Río La Vieja. A 3 minutos de Cartago."
  whatsappMessage={SITE.whatsappMessages.tumbaga}
>
  <!-- Hero -->
  <section class="relative flex min-h-[90vh] items-center justify-center overflow-hidden bg-brand-forest text-brand-cream">
    <Image
      src={tumbagaMirador}
      alt="Vista aérea del mirador Río La Vieja, Tumbaga"
      class="absolute inset-0 h-full w-full object-cover"
      width={1200}
      priority
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-charcoal/45 via-brand-charcoal/15 to-brand-forest/65"></div>

    <div class="relative z-10 mx-auto max-w-3xl px-4 text-center">
      <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full border-2 border-brand-gold bg-brand-charcoal/60">
        <span class="font-display text-[10px] uppercase leading-tight tracking-wide text-brand-gold-light">
          [Logo Tumbaga]
        </span>
      </div>
      <h1 class="font-display text-4xl font-bold uppercase leading-tight tracking-wide drop-shadow-[0_2px_10px_rgba(0,0,0,0.55)] md:text-6xl">
        Te mereces todo con tu familia.
      </h1>
      <p class="mt-5 text-lg text-brand-cream/90 drop-shadow-[0_2px_8px_rgba(0,0,0,0.55)] md:text-xl">
        Lotes campestres desde 1.500 m² con vista a todo el norte del Valle. A solo 3 minutos de Cartago.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={waLink(SITE.whatsappMessages.tumbaga)}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full rounded-full bg-brand-gold px-8 py-3 text-center font-display text-sm uppercase tracking-wide text-brand-charcoal transition-transform hover:scale-105 sm:w-auto"
        >
          Agenda tu visita
        </a>
        <a
          href="#lotes"
          class="w-full rounded-full border-2 border-brand-cream px-8 py-3 text-center font-display text-sm uppercase tracking-wide text-brand-cream transition-transform hover:scale-105 sm:w-auto"
        >
          Ver lotes disponibles
        </a>
      </div>
    </div>
  </section>

  <!-- Datos clave -->
  <div class="bg-brand-gold px-4 py-4">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-8 gap-y-2">
      {datosClave.map((dato, i) => (
        <span class="font-display text-xs uppercase tracking-wide text-brand-charcoal md:text-sm">
          {dato}{i < datosClave.length - 1 ? <span class="ml-8 hidden text-brand-charcoal/40 md:inline">•</span> : null}
        </span>
      ))}
    </div>
  </div>

  <!-- Antes/después -->
  <section class="bg-brand-cream px-4 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-display text-3xl font-bold uppercase tracking-wide text-brand-forest md:text-4xl">
        El lote real, la casa posible
      </h2>
      <p class="mt-4 text-brand-charcoal/80">
        Arrastra para comparar el terreno tal como está hoy con la casa campestre que podrías construir.
      </p>
    </div>
    <div class="mt-10">
      <BeforeAfterSlider
        beforeImage={antesRender}
        beforeAlt="Foto real del lote en Tumbaga"
        afterImage={despuesRender}
        afterAlt="Render de la casa posible sobre el lote"
      />
    </div>
    <div class="mx-auto mt-8 max-w-2xl text-center">
      <p class="text-brand-charcoal/80">
        Este render es real: es la casa que podemos diseñar y construir para ti sobre tu lote.
        Compra tu lote en Tumbaga y nosotros nos encargamos del resto, del diseño a la entrega de llaves.
      </p>
      <a
        href={waLink(SITE.whatsappMessages.construccion)}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-5 inline-block rounded-full bg-brand-forest px-8 py-3 font-display text-sm uppercase tracking-wide text-brand-cream transition-transform hover:scale-105"
      >
        Quiero mi casa en Tumbaga
      </a>
    </div>
  </section>

  <!-- Plano interactivo de lotes -->
  <section id="lotes" class="bg-brand-forest px-4 py-16 text-brand-cream md:px-8 md:py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-3xl font-bold uppercase tracking-wide md:text-4xl">
        Elige tu lote
      </h2>
      <p class="mt-3 text-center text-sm text-brand-cream/70">
        17 lotes campestres sobre el plano oficial de parcelación.
      </p>
      <div class="mt-10">
        <TumbagaLotMap />
      </div>

      <!-- Lista compacta de disponibilidad -->
      <div class="mx-auto mt-10 grid max-w-4xl grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
        {tumbagaLots.map((lot) => (
          lot.estado === "disponible" ? (
            <a
              href={waLink(lotWhatsappMessage(lot))}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border border-brand-gold/40 bg-brand-charcoal/40 p-3 text-center transition-colors hover:border-brand-gold"
            >
              <p class="font-display text-sm font-bold uppercase tracking-wide text-brand-gold-light">
                Lote {lot.num}
              </p>
              <p class="mt-1 text-xs text-brand-cream/80">{lot.area}</p>
              <p class="mt-1 font-display text-[10px] uppercase tracking-wide text-brand-gold">Disponible</p>
            </a>
          ) : (
            <div class="rounded-lg border border-brand-cream/10 bg-brand-charcoal/60 p-3 text-center opacity-60">
              <p class="font-display text-sm font-bold uppercase tracking-wide text-brand-cream/70">
                Lote {lot.num}
              </p>
              <p class="mt-1 text-xs text-brand-cream/50">{lot.area}</p>
              <p class="mt-1 font-display text-[10px] uppercase tracking-wide text-brand-cream/50">Vendido</p>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- Galería -->
  <section class="bg-brand-cream px-4 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-3xl font-bold uppercase tracking-wide text-brand-forest md:text-4xl">
        Así se ve Tumbaga
      </h2>
      <p class="mt-3 text-center text-sm text-brand-charcoal/60">
        Fotografía real de dron del condominio y su entorno.
      </p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {galeria.map((foto, i) => (
          <div class="overflow-hidden rounded-xl shadow-md">
            <Image
              src={foto}
              alt={`Vista aérea del Condominio Tumbaga ${i + 1}`}
              class="h-56 w-full object-cover transition-transform duration-300 hover:scale-105"
              width={600}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ubicación -->
  <section class="bg-brand-cream px-4 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-3xl font-bold uppercase tracking-wide text-brand-forest md:text-4xl">
        Ubicación
      </h2>
      <div class="mt-10 overflow-hidden rounded-xl border border-brand-forest/10 shadow-lg">
        <iframe
          src={mapsSrc}
          class="h-80 w-full md:h-96"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Condominio Tumbaga, vía Cartago–Cerritos"
        ></iframe>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {distancias.map((d) => (
          <div class="rounded-lg bg-brand-forest/5 p-4 text-center">
            <p class="font-display text-sm uppercase tracking-wide text-brand-forest">{d.lugar}</p>
            <p class="mt-1 text-brand-charcoal/70">{d.tiempo}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sala de ventas + CTA -->
  <section class="bg-brand-charcoal px-4 py-20 text-center text-brand-cream md:px-8">
    <h2 class="font-display text-3xl font-bold uppercase tracking-wide md:text-4xl">
      Visítanos en nuestra sala de ventas
    </h2>
    <p class="mt-4 text-brand-cream/80">{SITE.salesOffice}</p>
    <a
      href={waLink(SITE.whatsappMessages.tumbaga)}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-block rounded-full bg-brand-gold px-10 py-3 font-display text-sm uppercase tracking-wide text-brand-charcoal transition-transform hover:scale-105"
    >
      Agenda tu visita
    </a>
  </section>
</Layout>
