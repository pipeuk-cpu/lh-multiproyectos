---
import { Image } from "astro:assets";
import { waLink } from "../config/site";
import type { LocalComercial } from "../types/local";

interface Props {
  local: LocalComercial;
}

const { local } = Astro.props;
---

<div class="group flex flex-col overflow-hidden rounded-xl border border-brand-gold/30 bg-white transition-colors hover:border-brand-gold">
  <div class="relative h-44 overflow-hidden">
    {local.image ? (
      <Image
        src={local.image}
        alt={`Local comercial en ${local.direccion}`}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        widths={[400, 800]}
        sizes="(min-width: 640px) 50vw, 100vw"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-brand-forest to-brand-charcoal">
        <span class="px-4 text-center font-display text-xs uppercase tracking-wide text-brand-cream/40">
          [PENDIENTE: foto del local]
        </span>
      </div>
    )}
    <span class="absolute right-3 top-3 rounded-full bg-brand-gold px-3 py-1 font-display text-xs uppercase tracking-wide text-brand-charcoal">
      {local.modalidad}
    </span>
  </div>
  <div class="flex flex-1 flex-col gap-2 p-5">
    <p class="font-display text-sm uppercase tracking-wide text-brand-forest">{local.direccion}</p>
    <div class="flex items-center justify-between text-sm text-brand-charcoal/70">
      <span>{local.area}</span>
      {local.precio ? <span>{local.precio}</span> : null}
    </div>
    <a
      href={waLink(local.whatsappMessage)}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 rounded-full bg-brand-gold px-5 py-2 text-center font-display text-xs uppercase tracking-wide text-brand-charcoal transition-transform hover:scale-105"
    >
      Consultar por WhatsApp
    </a>
  </div>
</div>
