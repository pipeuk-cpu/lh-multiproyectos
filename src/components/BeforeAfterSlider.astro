---
import { Image } from "astro:assets";

interface Props {
  beforeLabel?: string;
  afterLabel?: string;
  beforeImage?: ImageMetadata;
  afterImage?: ImageMetadata;
  beforeAlt?: string;
  afterAlt?: string;
}

const {
  beforeLabel = "ANTES",
  afterLabel = "DESPUÉS",
  beforeImage,
  afterImage,
  beforeAlt = "Foto real del lote",
  afterAlt = "Render de la propiedad posible",
} = Astro.props;
---

<div
  class="ba-slider relative aspect-4/3 w-full max-w-3xl mx-auto select-none overflow-hidden rounded-xl shadow-xl md:aspect-video"
  style="--pos: 50%"
>
  <!-- Capa DESPUÉS (render), de fondo, ocupa todo el marco -->
  <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-forest to-aldea-green text-brand-cream">
    {afterImage ? (
      <Image src={afterImage} alt={afterAlt} width={800} class="h-full w-full object-cover" />
    ) : (
      <span class="font-display text-sm uppercase tracking-wide opacity-70">[PENDIENTE: render de la casa]</span>
    )}
    <span class="absolute right-3 top-3 rounded bg-black/40 px-2 py-1 font-display text-xs uppercase tracking-wide text-brand-cream">
      {afterLabel}
    </span>
  </div>

  <!-- Capa ANTES (foto real), recortada al ancho de --pos mediante clip-path -->
  <div
    class="ba-before absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-charcoal to-brand-forest text-brand-cream"
    style="clip-path: inset(0 calc(100% - var(--pos)) 0 0)"
  >
    {beforeImage ? (
      <Image src={beforeImage} alt={beforeAlt} width={800} class="h-full w-full object-cover" />
    ) : (
      <span class="font-display text-sm uppercase tracking-wide opacity-70">[PENDIENTE: video/foto dron del lote]</span>
    )}
    <span class="absolute left-3 top-3 rounded bg-black/40 px-2 py-1 font-display text-xs uppercase tracking-wide text-brand-cream">
      {beforeLabel}
    </span>
  </div>

  <!-- Manija -->
  <div class="ba-handle pointer-events-none absolute inset-y-0 flex w-0.5 -translate-x-1/2 items-center bg-brand-gold" style="left: var(--pos)">
    <div
      class="ba-thumb pointer-events-auto flex h-10 w-10 -translate-x-1/2 cursor-ew-resize items-center justify-center rounded-full border-2 border-brand-gold bg-brand-cream shadow-lg focus:outline-none focus:ring-2 focus:ring-brand-gold/70"
      role="slider"
      tabindex="0"
      aria-label="Comparador antes y después"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="50"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5 fill-brand-forest"><path d="M8 5l-6 7 6 7V5zm8 0v14l6-7-6-7z"/></svg>
    </div>
  </div>
</div>

<script>
  function initSliders() {
    document.querySelectorAll<HTMLElement>(".ba-slider").forEach((slider) => {
      if (slider.dataset.initialized) return;
      slider.dataset.initialized = "true";

      const handle = slider.querySelector<HTMLElement>(".ba-handle");
      const thumb = slider.querySelector<HTMLElement>(".ba-thumb");
      let dragging = false;
      let pos = 50;

      const apply = (pct: number) => {
        pos = Math.min(100, Math.max(0, pct));
        slider.style.setProperty("--pos", `${pos}%`);
        thumb?.setAttribute("aria-valuenow", String(Math.round(pos)));
      };

      const setPos = (clientX: number) => {
        const rect = slider.getBoundingClientRect();
        apply(((clientX - rect.left) / rect.width) * 100);
      };

      thumb?.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "ArrowLeft") apply(pos - 5);
        else if (e.key === "ArrowRight") apply(pos + 5);
        else if (e.key === "Home") apply(0);
        else if (e.key === "End") apply(100);
        else return;
        e.preventDefault();
      });

      const start = (e: PointerEvent) => {
        dragging = true;
        setPos(e.clientX);
      };
      const move = (e: PointerEvent) => {
        if (!dragging) return;
        setPos(e.clientX);
      };
      const end = () => {
        dragging = false;
      };

      handle?.addEventListener("pointerdown", start);
      slider.addEventListener("pointerdown", start);
      window.addEventListener("pointermove", move);
      window.addEventListener("pointerup", end);
      window.addEventListener("pointercancel", end);
    });
  }

  initSliders();
  document.addEventListener("astro:page-load", initSliders);
</script>
