---
import { Image } from "astro:assets";
import { waLink } from "../config/site";
import { tumbagaLots, tumbagaComerciales, lotWhatsappMessage } from "../data/tumbaga-lots";
import planoLotes from "../assets/tumbaga/plano-lotes.png";

const disponibles = tumbagaLots.filter((l) => l.estado === "disponible").length;
---

<div class="mx-auto max-w-4xl">
  <div class="mb-4 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
    <span class="flex items-center gap-2">
      <span class="inline-block h-4 w-4 rounded-full bg-brand-gold"></span>
      Disponible ({disponibles})
    </span>
    <span class="flex items-center gap-2">
      <span class="inline-block h-4 w-4 rounded-full bg-brand-charcoal/60"></span>
      Vendido ({tumbagaLots.length - disponibles})
    </span>
    <span class="text-brand-cream/60">Toca un lote para consultar por WhatsApp</span>
  </div>

  <div class="relative overflow-hidden rounded-xl bg-white shadow-xl">
    <Image
      src={planoLotes}
      alt="Plano de parcelación del Condominio Tumbaga con los 17 lotes"
      class="h-auto w-full"
      width={1100}
    />

    {tumbagaLots.map((lot) => (
      lot.estado === "disponible" ? (
        <a
          href={waLink(lotWhatsappMessage(lot))}
          target="_blank"
          rel="noopener noreferrer"
          class="group absolute flex h-8 w-8 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border-2 border-white bg-brand-gold font-display text-xs font-bold text-brand-charcoal shadow-md transition-transform hover:scale-125 focus:outline-none focus:ring-2 focus:ring-brand-forest md:h-9 md:w-9 md:text-sm"
          style={`left: ${lot.pos.x}%; top: ${lot.pos.y}%`}
          aria-label={`Lote ${lot.num}, ${lot.area}, disponible. Consultar por WhatsApp`}
        >
          {lot.num}
          <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 hidden -translate-x-1/2 whitespace-nowrap rounded bg-brand-charcoal px-2 py-1 text-xs text-brand-cream group-hover:block group-focus:block">
            Lote {lot.num} · {lot.area} · Disponible
          </span>
        </a>
      ) : (
        <span
          class="group absolute flex h-8 w-8 -translate-x-1/2 -translate-y-1/2 cursor-not-allowed items-center justify-center rounded-full border-2 border-white/60 bg-brand-charcoal/60 font-display text-xs font-bold text-brand-cream/80 shadow-md md:h-9 md:w-9 md:text-sm"
          style={`left: ${lot.pos.x}%; top: ${lot.pos.y}%`}
          aria-label={`Lote ${lot.num}, ${lot.area}, vendido`}
          tabindex="0"
        >
          {lot.num}
          <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 hidden -translate-x-1/2 whitespace-nowrap rounded bg-brand-charcoal px-2 py-1 text-xs text-brand-cream group-hover:block group-focus:block">
            Lote {lot.num} · {lot.area} · Vendido
          </span>
        </span>
      )
    ))}

    {tumbagaComerciales.map((lot) => (
      lot.estado === "disponible" ? (
        <a
          href={waLink(`Hola, quiero información sobre el Lote comercial ${lot.id} (${lot.area}) en Tumbaga.`)}
          target="_blank"
          rel="noopener noreferrer"
          class="group absolute flex h-8 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border-2 border-white bg-brand-forest px-2 font-display text-xs font-bold text-brand-cream shadow-md transition-transform hover:scale-110 focus:outline-none focus:ring-2 focus:ring-brand-gold"
          style={`left: ${lot.pos.x}%; top: ${lot.pos.y}%`}
          aria-label={`Lote comercial ${lot.id}, ${lot.area}, disponible. Consultar por WhatsApp`}
        >
          C-{lot.id}
          <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 hidden -translate-x-1/2 whitespace-nowrap rounded bg-brand-charcoal px-2 py-1 text-xs text-brand-cream group-hover:block group-focus:block">
            Lote comercial {lot.id} · {lot.area} · Disponible
          </span>
        </a>
      ) : (
        <span
          class="group absolute flex h-8 -translate-x-1/2 -translate-y-1/2 cursor-not-allowed items-center justify-center rounded-full border-2 border-white/60 bg-brand-charcoal/60 px-2 font-display text-xs font-bold text-brand-cream/80 shadow-md"
          style={`left: ${lot.pos.x}%; top: ${lot.pos.y}%`}
          aria-label={`Lote comercial ${lot.id}, ${lot.area}, vendido`}
          tabindex="0"
        >
          C-{lot.id}
          <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 hidden -translate-x-1/2 whitespace-nowrap rounded bg-brand-charcoal px-2 py-1 text-xs text-brand-cream group-hover:block group-focus:block">
            Lote comercial {lot.id} · {lot.area} · Vendido
          </span>
        </span>
      )
    ))}
  </div>
  <p class="mt-3 text-center text-xs text-brand-cream/60">
    Plano oficial de parcelación (mayo 2023). Áreas exactas por lote.
  </p>
</div>
